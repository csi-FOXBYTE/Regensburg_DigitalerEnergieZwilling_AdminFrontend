# Copy this file to .env.development.local (already in .gitignore) and fill in the values.
# Neither variable has any effect in `vite build` — dev-auth code is dead-code-eliminated in prod.

# APISIX gateway base URL. In production, requests are same-origin so this should be left empty.
VITE_API_BASE_URL=http://localhost:5000

# Dev JWT. Generate in the backend repo with:
#   pnpm jwt:dev --ttl 2592000 --output raw
# 30-day TTL avoids frequent regeneration during local development.
VITE_DEV_ACCESS_TOKEN=<paste token here>
